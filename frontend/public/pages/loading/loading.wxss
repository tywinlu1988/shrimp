/**
 * 拔草大虾 - 加载页样式文件
 * pages/loading/loading.wxss
 */

/* 加载页容器 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background-color: var(--background-color);
  padding: 40rpx;
}

/* 虾动画容器 */
.shrimp-animation-container {
  width: 300rpx;
  height: 300rpx;
  position: relative;
  margin-bottom: 60rpx;
}

/* 虾动画 */
.shrimp-image {
  width: 100%;
  height: 100%;
  animation: bounce 1.5s infinite ease-in-out;
}

/* 草动画 */
.grass-image {
  position: absolute;
  width: 120rpx;
  height: 120rpx;
  bottom: 0;
  right: -20rpx;
  animation: shake 2s infinite ease-in-out;
}

/* 加载标题 */
.loading-title {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--primary-color);
  margin-bottom: 30rpx;
  text-align: center;
}

/* 加载状态文本 */
.loading-status {
  font-size: 32rpx;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  text-align: center;
  min-height: 45rpx;
}

/* 加载提示文本 */
.loading-tip {
  font-size: 28rpx;
  color: var(--text-secondary);
  text-align: center;
  margin-bottom: 40rpx;
}

/* 进度条容器 */
.progress-container {
  width: 80%;
  height: 20rpx;
  background-color: rgba(99, 102, 241, 0.1);
  border-radius: 10rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

/* 进度条 */
.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, var(--primary-light), var(--primary-dark));
  border-radius: 10rpx;
  transition: width 0.3s ease;
}

/* 进度文本 */
.progress-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  text-align: center;
}

/* 取消按钮 */
.cancel-button {
  margin-top: 60rpx;
  padding: 16rpx 40rpx;
  background-color: transparent;
  border: 2rpx solid var(--border-color);
  border-radius: 100rpx;
  color: var(--text-secondary);
  font-size: 28rpx;
}

.cancel-button:active {
  background-color: rgba(0, 0, 0, 0.05);
}

/* 错误状态容器 */
.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  text-align: center;
}

.error-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 30rpx;
}

.error-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--danger-color);
  margin-bottom: 20rpx;
}

.error-message {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 40rpx;
  line-height: 1.5;
}

.retry-button {
  background: linear-gradient(135deg, var(--primary-light), var(--primary-dark));
  color: white;
  padding: 20rpx 60rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  margin-top: 20rpx;
}

/* 动画定义 */
@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-20rpx);
  }
}

@keyframes shake {
  0%, 100% {
    transform: rotate(-5deg);
  }
  50% {
    transform: rotate(5deg);
  }
}

/* 淡入动画 */
.fade-in {
  animation: fadeIn 0.5s ease-in-out;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

/* 状态文本动画 */
.status-text-animate {
  animation: statusTextFade 2s infinite;
}

@keyframes statusTextFade {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.6;
  }
}

/* 加载点动画 */
.loading-dots:after {
  content: '';
  animation: dots 1.5s infinite;
}

@keyframes dots {
  0%, 20% {
    content: '.';
  }
  40% {
    content: '..';
  }
  60%, 100% {
    content: '...';
  }
}

/* 响应式调整 */
@media (min-height: 700px) {
  .shrimp-animation-container {
    width: 360rpx;
    height: 360rpx;
  }
  
  .loading-title {
    font-size: 44rpx;
  }
}