<!-- 拔草大虾 - 报告页面 -->
<view class="report-container">
  <!-- 加载状态 -->
  <block wx:if="{{pageState === 'loading'}}">
    <view class="loading-container">
      <image class="loading-animation animate-bounce" src="/assets/images/loading-shrimp.png" mode="aspectFit"></image>
      <view class="loading-text">正在生成拔草报告...</view>
      <view class="text-secondary text-sm mt-2">这可能需要几秒钟时间</view>
    </view>
  </block>

  <!-- 错误状态 -->
  <block wx:elif="{{pageState === 'error'}}">
    <view class="error-container">
      <image class="error-icon" src="/assets/images/error-icon.png" mode="aspectFit"></image>
      <view class="error-title">哎呀，出错了</view>
      <view class="error-message">{{errorMsg || '加载报告时发生错误，请稍后再试'}}</view>
      <view class="flex">
        <button class="retry-button" bindtap="retryLoading">重新加载</button>
        <button class="retry-button" style="margin-left: 20rpx; background-color: var(--text-secondary);" bindtap="goToHome">返回首页</button>
      </view>
    </view>
  </block>

  <!-- 成功状态 - 报告内容 -->
  <block wx:elif="{{pageState === 'success'}}">
    <!-- 商品信息卡片 -->
    <view class="report-header">
      <view class="product-card" bindtap="viewOriginalProduct">
        <image class="product-image" src="{{productInfo.image_url || '/assets/images/default-product.png'}}" mode="aspectFill"></image>
        <view class="product-info">
          <view>
            <view class="product-title">{{productInfo.title || '未知商品'}}</view>
            <view class="product-platform">{{productInfo.platform || '未知平台'}}</view>
          </view>
          <view class="product-price">{{productInfo.price || '¥??'}}</view>
        </view>
      </view>
    </view>

    <!-- 拔草指数区域 -->
    <view class="score-section">
      <view class="score-title">拔草指数</view>
      <view class="gauge-wrapper">
        <!-- 仪表盘背景 -->
        <image class="gauge-background" src="/assets/images/gauge-bg.png" mode="aspectFit"></image>
        
        <!-- 仪表盘进度 -->
        <image 
          class="gauge-progress" 
          src="/assets/images/gauge-progress.png" 
          mode="aspectFit" 
          style="transform: rotate({{weedOutScore * 1.8 - 90}}deg);"
        ></image>
        
        <!-- 分数显示 -->
        <view class="score-value">{{weedOutScore}}</view>
      </view>
      <view class="score-label">分数越高，拔草建议越强烈</view>
      
      <!-- 一句话总结 -->
      <view class="summary">{{summary}}</view>
    </view>

    <!-- 优点区域 -->
    <view class="pros-cons-section">
      <view class="section-card">
        <view class="section-header">
          <image class="section-icon" src="/assets/images/thumbs-up.png" mode="aspectFit"></image>
          <view class="section-title pros-title">值得点赞的优点</view>
        </view>
        
        <!-- 优点标签云 -->
        <view class="tag-cloud">
          <view wx:for="{{positiveTags}}" wx:key="index" class="tag tag-positive">{{item}}</view>
        </view>
        
        <!-- 优点评价列表 -->
        <view class="review-list" wx:if="{{pros.length > 0}}">
          <view wx:for="{{pros}}" wx:key="index" class="review-item review-item-pro">
            <view class="review-title">{{item.title}}</view>
            <view class="review-content">{{item.content}}</view>
            <view class="review-source">{{item.source}}</view>
          </view>
        </view>
        <view wx:else class="text-center text-secondary p-4">暂无明显优点</view>
      </view>
    </view>

    <!-- 缺点区域 -->
    <view class="pros-cons-section">
      <view class="section-card">
        <view class="section-header">
          <image class="section-icon" src="/assets/images/warning.png" mode="aspectFit"></image>
          <view class="section-title cons-title">必须警惕的槽点</view>
        </view>
        
        <!-- 缺点标签云 -->
        <view class="tag-cloud">
          <view wx:for="{{negativeTags}}" wx:key="index" class="tag tag-negative">{{item}}</view>
        </view>
        
        <!-- 缺点评价列表 -->
        <view class="review-list" wx:if="{{cons.length > 0}}">
          <view wx:for="{{cons}}" wx:key="index" class="review-item review-item-con">
            <view class="review-title">{{item.title}}</view>
            <view class="review-content">{{item.content}}</view>
            <view class="review-source">{{item.source}}</view>
          </view>
        </view>
        <view wx:else class="text-center text-secondary p-4">暂未发现明显缺点</view>
      </view>
    </view>

    <!-- 全网声音区域 (非MVP功能) -->
    <!-- <view class="web-echo-section" wx:if="{{webEchos && webEchos.length > 0}}">
      <view class="section-card">
        <view class="section-header">
          <image class="section-icon" src="/assets/images/globe.png" mode="aspectFit"></image>
          <view class="section-title">全网都在聊什么</view>
        </view>
        
        <view class="echo-list">
          <view wx:for="{{webEchos}}" wx:key="index" class="echo-item">
            <view class="echo-source">{{item.source}}</view>
            <view class="echo-content">{{item.content}}</view>
            <view class="view-original" data-url="{{item.url}}" bindtap="openOriginalContent">查看原文</view>
          </view>
        </view>
      </view>
    </view> -->

    <!-- AI购买建议区域 (非MVP功能) -->
    <!-- <view class="ai-advice-section" wx:if="{{aiAdvice}}">
      <view class="ai-advice-header">
        <image class="ai-icon" src="/assets/images/ai-icon.png" mode="aspectFit"></image>
        <view class="ai-advice-title">拔草大虾的建议</view>
      </view>
      <view class="ai-advice-content">{{aiAdvice}}</view>
    </view> -->

    <!-- 底部区域 -->
    <view class="footer">
      <image class="footer-logo" src="/assets/images/logo-gray.png" mode="aspectFit"></image>
      <view>拔草大虾 - 您的专属AI购物决策军师</view>
    </view>

    <!-- 分享按钮 -->
    <view class="share-container" wx:if="{{showShareBtn}}">
      <button class="share-button" open-type="share" bindtap="onShareTap">
        <image class="share-icon" src="/assets/images/share-icon.png" mode="aspectFit"></image>
        分享给朋友，帮TA避坑
      </button>
    </view>
  </block>
</view>